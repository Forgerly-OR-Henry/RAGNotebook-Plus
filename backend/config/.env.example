# ==============================================
# RAGNotebook 后端单独启动配置模板
# ==============================================
# backend/src/main.py 只读取 backend/config/.env，并用于手动单独启动后端。
# 复制本文件为 backend/config/.env 后再按本机环境修改；不要提交 backend/config/.env。
#
# 注意：
# - backend/config/.env 用于手动单独启动后端。
# - config/.env 只用于 start.py 一键启动和统一管理。
# - config/apikey.txt 保存真实模型 API Key，不要提交。
# - front/.env 用于手动单独启动前端。

# ==============================================
# 服务端口与访问配置
# ==============================================
# 后端监听地址。0.0.0.0 表示允许局域网访问；仅本机访问可改为 127.0.0.1。
BACKEND_HOST=0.0.0.0
# 后端监听端口。
BACKEND_PORT=10001
# 后端 CORS 白名单，多个来源用英文逗号分隔。若修改前端端口，也请同步修改这里的端口。
CORS_ALLOW_ORIGINS=http://localhost:11111,http://127.0.0.1:11111

# ==============================================
# 数据库配置
# ==============================================
# PostgreSQL 连接字符串。优先级高于 POSTGRES_* 分项配置。
DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5432/rag_notebook
# PostgreSQL 用户名。
POSTGRES_USER=rag
# PostgreSQL 密码。修改 Docker 已初始化的数据卷后，需要同步修改数据库内用户密码。
POSTGRES_PASSWORD=rag
# PostgreSQL 主机。Docker 本地启动通常为 localhost；远端数据库填写域名或 IP。
POSTGRES_HOST=localhost
# PostgreSQL 端口。
POSTGRES_PORT=5432
# PostgreSQL 数据库名。
POSTGRES_DB=rag_notebook
# SQLAlchemy 连接池基础连接数。
DB_POOL_SIZE=10
# SQLAlchemy 连接池最大溢出连接数。
DB_MAX_OVERFLOW=20
# 是否打印 SQL 语句。调试 SQL 时可设为 true，日常建议 false。
SQL_ECHO=false
# 后端启动仅支持新库/空库，首次启动会创建当前表结构和 pgvector 索引表。
# 如果 public schema 中已有旧版本表，请先清空 schema 或重建 POSTGRES_DB。

# ==============================================
# 文件存储配置
# ==============================================
# 文件存储主机。localhost/127.0.0.1 表示保存到本机目录，并忽略协议、用户名、密码和端口。
FILE_STORAGE_HOST=localhost
# 远程文件传输协议。首期仅远程模式支持 sftp；本机模式忽略该配置。
FILE_STORAGE_PROTOCOL=sftp
# 远程 SFTP 端口。本机模式忽略该配置。
FILE_STORAGE_PORT=22
# 远程 SFTP 用户名。本机模式忽略该配置。
FILE_STORAGE_USERNAME=
# 远程 SFTP 密码。本机模式忽略该配置。
FILE_STORAGE_PASSWORD=
# 文件根目录。本机模式为空时默认 backend/data；远程模式必填，例如 /srv/ragnotebook/files。
FILE_STORAGE_BASE_DIR=
# 数据库中 storage_uri 使用的逻辑别名。
FILE_STORAGE_URI_ALIAS=files

# ==============================================
# 模型配置 - 共享连接
# ==============================================
# 阿里云百炼 API Key 文件路径。不要在 backend/config/.env 里填写真实 sk-xxxx；请写入 config/apikey.txt。
ALIYUN_ACCESS_KEY_SECRET=../../config/apikey.txt
# DashScope SDK 兼容别名。历史代码或第三方 SDK 可能读取该字段；通常留空，
# 后端会优先使用 ALIYUN_ACCESS_KEY_SECRET。
DASHSCOPE_API_KEY=
# 阿里云百炼 OpenAI 兼容接口地址，供阿里云模型共享。
ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Ollama 服务地址，供 Ollama LLM、嵌入、视觉模型共享。
OLLAMA_BASE_URL=http://localhost:11434

# ==============================================
# 模型配置 - LLM
# ==============================================
# 大语言模型类型：ALIYUN（阿里云百炼）| OLLAMA（本地 Ollama）。
LLM_TYPE=ALIYUN
# Agent 兼容 API Key 字段。通常留空；阿里云模式使用 ALIYUN_ACCESS_KEY_SECRET，
# 只有接入非阿里云兼容 Agent 实现时才需要单独填写。
CHAT_API_KEY=
# 阿里云聊天模型名称。
CHAT_MODEL_NAME=qwen3-max
# 阿里云聊天模型兼容别名。历史模块可能读取 ALIYUN_MODEL_NAME；留空时使用 CHAT_MODEL_NAME。
ALIYUN_MODEL_NAME=
# Ollama 聊天模型名称。使用前需先执行 ollama pull 下载。
OLLAMA_MODEL_NAME=qwen3.5:0.8b
# Ollama 聊天模型兼容别名。历史模块可能读取 OLLAMA_CHAT_MODEL_NAME；留空时使用 OLLAMA_MODEL_NAME。
OLLAMA_CHAT_MODEL_NAME=
# 直接聊天保留的历史轮数。0 表示不带历史；数值越大，上下文越完整但模型调用越慢。
CHAT_HISTORY_TURNS=6

# ==============================================
# 模型配置 - 嵌入
# ==============================================
# 嵌入模型类型：ALIYUN | OLLAMA。
EMBED_MODEL_TYPE=ALIYUN
# 阿里云嵌入模型名称。仅 EMBED_MODEL_TYPE=ALIYUN 时使用。
ALIYUN_EMBED_MODEL_NAME=text-embedding-v4
# Ollama 嵌入模型名称。仅 EMBED_MODEL_TYPE=OLLAMA 时使用。
TEXT_EMBEDDING_MODEL_NAME=qwen3-embedding:0.6b
# pgvector embedding 列维度。需与当前嵌入模型实际输出维度一致。
EMBEDDING_DIM=1024
# 查询 embedding 的内存缓存上限。提高该值可减少重复查询的嵌入调用，但会占用更多内存。
QUERY_EMBEDDING_CACHE_MAX=128

# ==============================================
# 模型配置 - 视觉
# ==============================================
# 视觉模型类型：ALIYUN | OLLAMA。必须显式填写，不再默认沿用 LLM_TYPE。
VISION_MODEL_TYPE=ALIYUN
# 阿里云视觉模型名称，建议使用 qwen-vl 系列。
VISION_CHAT_MODEL_NAME=qwen-vl-max
# Ollama 视觉模型名称。仅 VISION_MODEL_TYPE=OLLAMA 时使用。
VISION_OLLAMA_MODEL_NAME=qwen-vl:7b
# 多模态 PDF 每批处理页数。越大越省调用次数，但单页描述粒度可能下降。
VISION_BATCH_SIZE=5
# 是否启用图片感知哈希去重。PPT 或模板类 PDF 通常建议开启。
VISION_DEDUP_ENABLED=true
# 感知哈希距离阈值，范围 0-64；越小越严格。
VISION_DEDUP_THRESHOLD=10
# 批处理视觉模型时是否使用低分辨率图片，以节省 token 和传输体积。
VISION_BATCH_LOW_RES=true

# ==============================================
# 模型配置 - 重排序
# ==============================================
# 重排序模型本地路径。不存在时会尝试从 ModelScope 下载。
RERANKER_MODEL_PATH=models\bge-reranker-v2-m3

# ==============================================
# 访问控制与本地开发配置
# ==============================================
# 全局限流开关。开发调试可设为 false，生产环境建议 true。
RATE_LIMIT_ENABLED=false
# 本地开发默认创建 admin/admin1234 测试用户；非本地环境建议设为 false。
SEED_TEST_USER=true

# ==============================================
# 认证与令牌配置
# ==============================================
# JWT 签名密钥。生产环境务必修改为足够复杂的随机字符串。
SECRET_KEY=change-me
# JWT 签名算法。
ALGORITHM=HS256
# Token 黑名单状态本地缓存 TTL，单位秒。调小会更快感知登出/吊销，调大会减少数据库检查。
TOKEN_BLACKLIST_CACHE_TTL_SECONDS=5
