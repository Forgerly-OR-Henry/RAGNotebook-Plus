# ==============================================
# RAGNotebook backend standalone config
# ==============================================
# start.py uses ../config/.env and injects env vars into the backend process.
# This file is only for manually running the backend from the backend/ directory.
# Copy to backend/.env for standalone backend runs. Do not commit backend/.env.

BACKEND_HOST=0.0.0.0
BACKEND_PORT=10000
CORS_ALLOW_ORIGINS=http://localhost:10100,http://127.0.0.1:10100

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5432/rag_notebook
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rag_notebook
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
SQL_ECHO=false
PG_AUTO_INIT=true
DB_AUTO_CREATE_TABLES=false

# File storage
FILE_STORAGE_HOST=localhost
FILE_STORAGE_PROTOCOL=sftp
FILE_STORAGE_PORT=22
FILE_STORAGE_USERNAME=
FILE_STORAGE_PASSWORD=
FILE_STORAGE_BASE_DIR=
FILE_STORAGE_URI_ALIAS=files

# Shared model endpoints
ALIYUN_ACCESS_KEY_SECRET=../config/apikey.txt
ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OLLAMA_BASE_URL=http://localhost:11434

# LLM
LLM_TYPE=ALIYUN
CHAT_MODEL_NAME=qwen3-max
OLLAMA_MODEL_NAME=qwen3.5:0.8b

# Embedding
EMBED_MODEL_TYPE=ALIYUN
ALIYUN_EMBED_MODEL_NAME=text-embedding-v4
TEXT_EMBEDDING_MODEL_NAME=qwen3-embedding:0.6b
EMBEDDING_DIM=1024

# Vision
VISION_MODEL_TYPE=ALIYUN
VISION_CHAT_MODEL_NAME=qwen-vl-max
VISION_OLLAMA_MODEL_NAME=qwen-vl:7b
VISION_BATCH_SIZE=5
VISION_DEDUP_ENABLED=true
VISION_DEDUP_THRESHOLD=10
VISION_BATCH_LOW_RES=true

# Reranker
RERANKER_MODEL_PATH=D:\Hugging_Face\models\bge-reranker-v2-m3

# Runtime
RATE_LIMIT_ENABLED=false
SECRET_KEY=change-me
ALGORITHM=HS256
